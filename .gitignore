# =========================
# RimWorld Mod .gitignore
# =========================

# Machine-specific game paths (lives outside repo but just in case)
RimWorld.Paths.props

# Visual Studio
.vs/
*.user
*.suo
*.cache
*.rsuser

# Build artifacts
[Oo]bj/
[Bb]in/
[Dd]ebug/
[Rr]elease/
*.pdb

# Don't commit compiled DLLs in Assemblies — they're build output
# (uncomment if you DO want to ship pre-built DLLs for non-dev users)
# 1.6/Assemblies/*.dll

# NuGet
*.nuget.props
*.nuget.targets
*.nuget.dgspec.json
*.nuget.cache
project.assets.json
project.lock.json

# Rider
.idea/

# OS files
Thumbs.db
.DS_Store

# Build logs
build.log
build_err.log
build_restore.log
build_restore_err.log
*.binlog
