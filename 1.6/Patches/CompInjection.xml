<?xml version="1.0" encoding="utf-8"?>
<!--
  R4 Comp Injection — Safe Two-Step Pattern (MVP: Apparel only)
  
  Step 1: Create <comps> node on any matching def that lacks it.
  Step 2: Inject CompProperties_Recyclable, guarded against duplicates.
  
  Uses thingClass targeting (stable) rather than thingCategories (fragile).
  Each operation is fully independent and atomic.
  No PatchOperationSequence, no PatchOperationConditional, no PatchOperationTest.
  
  MVP scope: Only targets Apparel thingClass for now. Weapons will be added
  after we confirm this loads cleanly.
-->
<Patch>

  <!-- Step 1: Ensure <comps> node exists on apparel defs that lack it -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[thingClass="Apparel" and not(comps)]</xpath>
    <value>
      <comps/>
    </value>
  </Operation>

  <!-- Step 2: Inject comp on apparel defs, skip if already present -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[thingClass="Apparel" and not(comps/li[@Class="RRRR.CompProperties_Recyclable"])]/comps</xpath>
    <value>
      <li Class="RRRR.CompProperties_Recyclable"/>
    </value>
  </Operation>

</Patch>
