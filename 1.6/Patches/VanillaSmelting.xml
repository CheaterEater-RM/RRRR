<?xml version="1.0" encoding="utf-8"?>
<!--
  R4 Vanilla Smelting Override

  Removes SmeltWeapon, SmeltApparel, and SmeltOrDestroyThing from the electric
  smelter. Our per-bench recycle bills replace the first two with skill-based
  recycling. SmeltOrDestroyThing is also removed as it duplicates functionality
  now covered by the recycle bills.

  Kept intact:
    ExtractMetalFromSlag   — slag processing, unrelated to gear
    DestroyWeapon          — deliberate destruction, no material return
    DestroyApparel         — deliberate destruction, no material return

  NOTE: <success>Always</success> = don't fail if target node not found
  (valid values: Normal, Invert, Always, Never)
-->
<Patch>

  <Operation Class="PatchOperationRemove">
    <xpath>Defs/ThingDef[defName="ElectricSmelter"]/recipes/li[text()="SmeltWeapon"]</xpath>
    <success>Always</success>
  </Operation>

  <Operation Class="PatchOperationRemove">
    <xpath>Defs/ThingDef[defName="ElectricSmelter"]/recipes/li[text()="SmeltApparel"]</xpath>
    <success>Always</success>
  </Operation>

  <Operation Class="PatchOperationRemove">
    <xpath>Defs/ThingDef[defName="ElectricSmelter"]/recipes/li[text()="SmeltOrDestroyThing"]</xpath>
    <success>Always</success>
  </Operation>

</Patch>
