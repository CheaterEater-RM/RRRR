<?xml version="1.0" encoding="utf-8"?>
<!--
  R4 Recipe Definitions — Bill-based automation
  
  RECYCLE + CLEAN: Use vanilla's WorkGiver_DoBill + JobDriver_DoBill with custom
  RecipeWorkers. The item IS the ingredient; RecipeWorker handles the logic.
  
  REPAIR: Uses our custom WorkGiver_R4RepairBill which creates RRRR_Repair jobs
  with proper material hauling via CollectIngredientsToils. The requiredGiverWorkType
  is set to prevent vanilla's WorkGiver_DoBill from also processing repair bills.
-->
<Defs>

  <!-- ═══════════════════════════════════════════ -->
  <!-- RECYCLE BILLS (vanilla DoBill pipeline)     -->
  <!-- ═══════════════════════════════════════════ -->

  <RecipeDef>
    <defName>RRRR_RecycleWeapon</defName>
    <label>recycle weapon</label>
    <description>Break down a weapon to recover materials. Returns depend on condition, quality, and crafter skill — superior to basic smelting.</description>
    <jobString>Recycling weapon.</jobString>
    <workAmount>1600</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <workerClass>RRRR.RecipeWorker_R4Recycle</workerClass>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Weapons</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Weapons</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>ElectricSmelter</li>
      <li>ElectricSmithy</li>
      <li>FueledSmithy</li>
      <li>TableMachining</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>RRRR_RecycleApparel</defName>
    <label>recycle apparel</label>
    <description>Break down apparel to recover materials. Returns depend on condition, quality, and crafter skill — superior to basic smelting.</description>
    <jobString>Recycling apparel.</jobString>
    <workAmount>1600</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Tailor</effectWorking>
    <soundWorking>Recipe_Tailor</soundWorking>
    <workerClass>RRRR.RecipeWorker_R4Recycle</workerClass>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Apparel</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Apparel</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>ElectricSmelter</li>
      <li>ElectricTailoringBench</li>
      <li>HandTailoringBench</li>
    </recipeUsers>
  </RecipeDef>

  <!-- ═══════════════════════════════════════════ -->
  <!-- REPAIR BILLS (custom WorkGiver pipeline)    -->
  <!--                                             -->
  <!-- requiredGiverWorkType prevents vanilla's    -->
  <!-- WorkGiver_DoBill from processing these.     -->
  <!-- Our WorkGiver_R4RepairBill handles them     -->
  <!-- and creates RRRR_Repair jobs with proper    -->
  <!-- ingredient hauling.                         -->
  <!-- ═══════════════════════════════════════════ -->

  <RecipeDef>
    <defName>RRRR_RepairWeapon</defName>
    <label>repair weapon</label>
    <description>Repair a damaged weapon. Each cycle restores HP based on skill, consuming materials hauled to the bench. Items with minor damage (≤5%) are mended for free.</description>
    <jobString>Repairing weapon.</jobString>
    <workAmount>800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <workerClass>RRRR.RecipeWorker_R4Repair</workerClass>
    <!-- Block vanilla WorkGiver_DoBill: smithy uses Smithing, not Crafting -->
    <requiredGiverWorkType>Crafting</requiredGiverWorkType>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Weapons</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Weapons</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>ElectricSmithy</li>
      <li>FueledSmithy</li>
      <li>TableMachining</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>RRRR_RepairApparel</defName>
    <label>repair apparel</label>
    <description>Repair damaged apparel. Each cycle restores HP based on skill, consuming materials hauled to the bench. Items with minor damage (≤5%) are mended for free.</description>
    <jobString>Repairing apparel.</jobString>
    <workAmount>800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Tailor</effectWorking>
    <soundWorking>Recipe_Tailor</soundWorking>
    <workerClass>RRRR.RecipeWorker_R4Repair</workerClass>
    <!-- Block vanilla WorkGiver_DoBill: tailor uses Tailoring, not Crafting -->
    <requiredGiverWorkType>Crafting</requiredGiverWorkType>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Apparel</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Apparel</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>ElectricTailoringBench</li>
      <li>HandTailoringBench</li>
    </recipeUsers>
  </RecipeDef>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CLEAN BILLS (vanilla DoBill pipeline)       -->
  <!-- ═══════════════════════════════════════════ -->

  <RecipeDef>
    <defName>RRRR_CleanApparel</defName>
    <label>clean tainted apparel</label>
    <description>Remove corpse taint from apparel. The item is cleaned, not consumed.</description>
    <jobString>Cleaning taint from apparel.</jobString>
    <workAmount>800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Tailor</effectWorking>
    <soundWorking>Recipe_Tailor</soundWorking>
    <workerClass>RRRR.RecipeWorker_R4Clean</workerClass>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Apparel</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Apparel</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>ElectricTailoringBench</li>
      <li>HandTailoringBench</li>
    </recipeUsers>
  </RecipeDef>

</Defs>
