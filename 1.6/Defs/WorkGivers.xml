<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ═══════════════════════════════════════════ -->
  <!-- DESIGNATION-BASED WORK                      -->
  <!-- ═══════════════════════════════════════════ -->

  <WorkGiverDef>
    <defName>RRRR_Recycle</defName>
    <label>recycle designated items</label>
    <giverClass>RRRR.WorkGiver_R4Recycle</giverClass>
    <workType>Crafting</workType>
    <priorityInType>50</priorityInType>
    <verb>recycle</verb>
    <gerund>recycling designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Repair</defName>
    <label>repair designated items</label>
    <giverClass>RRRR.WorkGiver_R4Repair</giverClass>
    <workType>Crafting</workType>
    <priorityInType>55</priorityInType>
    <verb>repair</verb>
    <gerund>repairing designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Clean</defName>
    <label>clean tainted apparel</label>
    <giverClass>RRRR.WorkGiver_R4Clean</giverClass>
    <workType>Crafting</workType>
    <priorityInType>45</priorityInType>
    <verb>clean</verb>
    <gerund>cleaning tainted apparel</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <!-- ═══════════════════════════════════════════ -->
  <!-- BILL-BASED REPAIR                           -->
  <!--                                             -->
  <!-- Custom WorkGiver creates RRRR_Repair jobs   -->
  <!-- with proper material hauling. Recycle/clean  -->
  <!-- bills use vanilla's WorkGiver_DoBill.        -->
  <!--                                             -->
  <!-- workType must match the bench's vanilla      -->
  <!-- workType so the right pawns do the work.     -->
  <!-- ═══════════════════════════════════════════ -->

  <!-- Smithy: repair weapons (Smithing) -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Smithy</defName>
    <label>repair items at smithy</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Smithing</workType>
    <priorityInType>112</priorityInType>
    <fixedBillGiverDefs>
      <li>ElectricSmithy</li>
      <li>FueledSmithy</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at smithy</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Machining table: repair weapons (Smithing — same as vanilla DoBillsMachiningTable) -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Machining</defName>
    <label>repair items at machining table</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Smithing</workType>
    <priorityInType>72</priorityInType>
    <fixedBillGiverDefs>
      <li>TableMachining</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at machining table</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Tailor bench: repair apparel (Tailoring) -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Tailor</defName>
    <label>repair items at tailor bench</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Tailoring</workType>
    <priorityInType>107</priorityInType>
    <fixedBillGiverDefs>
      <li>ElectricTailoringBench</li>
      <li>HandTailoringBench</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at tailor bench</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

</Defs>
