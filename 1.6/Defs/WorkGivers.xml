<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- DESIGNATION-BASED WORK                                      -->
  <!--                                                             -->
  <!-- Each action (recycle, repair, clean) is registered under    -->
  <!-- multiple WorkGiverDefs matching the bench work types.       -->
  <!-- Clean also has a Smithing WorkGiver because flak/power       -->
  <!-- armour and other smithing-routed apparel can be tainted.    -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <!-- ─── RECYCLE ─────────────────────────────────────────────── -->

  <WorkGiverDef>
    <defName>RRRR_Recycle_Crafting</defName>
    <label>recycle items (craft)</label>
    <giverClass>RRRR.WorkGiver_R4Recycle</giverClass>
    <workType>Crafting</workType>
    <priorityInType>50</priorityInType>
    <verb>recycle</verb>
    <gerund>recycling designated items</gerund>
    <requiredCapacities><li>Manipulation</li></requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Recycle_Smithing</defName>
    <label>recycle items (smith)</label>
    <giverClass>RRRR.WorkGiver_R4Recycle</giverClass>
