<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- DESIGNATION-BASED WORK                                      -->
  <!-- These scan for player-designated items and route them to    -->
  <!-- the appropriate bench via WorkbenchRouter.GetValidBenches.  -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <WorkGiverDef>
    <defName>RRRR_Recycle</defName>
    <label>recycle designated items</label>
    <giverClass>RRRR.WorkGiver_R4Recycle</giverClass>
    <workType>Crafting</workType>
    <priorityInType>50</priorityInType>
    <verb>recycle</verb>
    <gerund>recycling designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Repair</defName>
    <label>repair designated items</label>
    <giverClass>RRRR.WorkGiver_R4Repair</giverClass>
    <workType>Crafting</workType>
    <priorityInType>55</priorityInType>
    <verb>repair</verb>
    <gerund>repairing designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Clean</defName>
    <label>clean tainted apparel</label>
    <giverClass>RRRR.WorkGiver_R4Clean</giverClass>
    <workType>Crafting</workType>
    <priorityInType>45</priorityInType>
    <verb>clean</verb>
    <gerund>cleaning tainted apparel</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- BILL-BASED REPAIR                                           -->
  <!--                                                             -->
  <!-- One WorkGiverDef per bench (or bench group). Each uses our  -->
  <!-- custom WorkGiver_R4RepairBill which creates RRRR_Repair     -->
  <!-- jobs with proper material hauling. The workType must match  -->
  <!-- the bench's vanilla workType so the right pawns work there. -->
  <!--                                                             -->
  <!-- Recycle and clean bills use vanilla's WorkGiver_DoBill      -->
  <!-- (no custom WorkGiver needed for those).                     -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <!-- Crafting spot: Crafting work type -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_CraftingSpot</defName>
    <label>repair items at crafting spot</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Crafting</workType>
    <priorityInType>52</priorityInType>
    <fixedBillGiverDefs>
      <li>CraftingSpot</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at crafting spot</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Tailor benches: Tailoring work type -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Tailor</defName>
    <label>repair items at tailor bench</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Tailoring</workType>
    <priorityInType>107</priorityInType>
    <fixedBillGiverDefs>
      <li>HandTailoringBench</li>
      <li>ElectricTailoringBench</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at tailor bench</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Smithy: Smithing work type -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Smithy</defName>
    <label>repair items at smithy</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Smithing</workType>
    <priorityInType>112</priorityInType>
    <fixedBillGiverDefs>
      <li>FueledSmithy</li>
      <li>ElectricSmithy</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at smithy</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Machining table: Smithing work type -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Machining</defName>
    <label>repair items at machining table</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Smithing</workType>
    <priorityInType>72</priorityInType>
    <fixedBillGiverDefs>
      <li>TableMachining</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at machining table</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

  <!-- Fabrication bench: Smithing work type -->
  <WorkGiverDef>
    <defName>RRRR_RepairBill_Fabrication</defName>
    <label>repair items at fabrication bench</label>
    <giverClass>RRRR.WorkGiver_R4RepairBill</giverClass>
    <workType>Smithing</workType>
    <priorityInType>68</priorityInType>
    <fixedBillGiverDefs>
      <li>FabricationBench</li>
    </fixedBillGiverDefs>
    <verb>repair at</verb>
    <gerund>repairing items at fabrication bench</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <prioritizeSustains>true</prioritizeSustains>
  </WorkGiverDef>

</Defs>
