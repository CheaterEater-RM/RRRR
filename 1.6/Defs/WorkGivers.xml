<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- ═══════════════════════════════════════════ -->
  <!-- DESIGNATION-BASED WORK                      -->
  <!-- ═══════════════════════════════════════════ -->

  <WorkGiverDef>
    <defName>RRRR_Recycle</defName>
    <label>recycle designated items</label>
    <giverClass>RRRR.WorkGiver_R4Recycle</giverClass>
    <workType>Crafting</workType>
    <priorityInType>50</priorityInType>
    <verb>recycle</verb>
    <gerund>recycling designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Repair</defName>
    <label>repair designated items</label>
    <giverClass>RRRR.WorkGiver_R4Repair</giverClass>
    <workType>Crafting</workType>
    <priorityInType>55</priorityInType>
    <verb>repair</verb>
    <gerund>repairing designated items</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>RRRR_Clean</defName>
    <label>clean tainted apparel</label>
    <giverClass>RRRR.WorkGiver_R4Clean</giverClass>
    <workType>Crafting</workType>
    <priorityInType>45</priorityInType>
    <verb>clean</verb>
    <gerund>cleaning tainted apparel</gerund>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <!-- ═══════════════════════════════════════════ -->
  <!-- BILL-BASED WORK                             -->
  <!--                                             -->
  <!-- Bill-based recycling and cleaning use        -->
  <!-- vanilla's WorkGiver_DoBill + JobDriver_DoBill-->
  <!-- pipeline with custom RecipeWorkers.          -->
  <!--                                             -->
  <!-- Vanilla's existing WorkGiverDefs for each   -->
  <!-- bench type (DoBillsSmelter, DoBillsMake-     -->
  <!-- Weapons, DoBillsMakeApparel) handle our      -->
  <!-- RecipeDefs automatically. No additional      -->
  <!-- WorkGiverDefs needed.                        -->
  <!-- ═══════════════════════════════════════════ -->

</Defs>
